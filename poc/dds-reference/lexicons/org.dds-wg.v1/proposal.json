{
  "lexicon": 1,
  "id": "org.dds-wg.v1.proposal",
  "description": "A named, described proposal authored by a user or algorithm.",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["name", "creator", "createdAt"],
        "properties": {
          "schemaVersion": { "type": "string", "maxLength": 32 },
          "name": { "type": "string", "maxLength": 200 },
          "description": { "type": "string", "maxLength": 10000 },
          "creator": {
            "type": "union",
            "refs": ["org.dds-wg.v1.defs#userAgent", "org.dds-wg.v1.defs#algorithmAgent"]
          },
          "step": { "type": "ref", "ref": "org.dds-wg.v1.defs#projectStepRef" },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
