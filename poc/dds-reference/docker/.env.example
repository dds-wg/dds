# Copy to .env (in this directory) and customize for your deployment.
# `docker compose -f compose.prod.yml --env-file docker/.env up -d --build`

# ----- Caddy / public URLs -----

# Hostname Caddy will serve. Use `:80` for HTTP-only on localhost, or a real hostname
# (e.g. `dds.example.com`) to enable automatic Let's Encrypt TLS.
PUBLIC_HOST=:80

# The public URL the browser uses to reach the stack. Used for OAuth redirects, CORS, and
# SvelteKit's `ORIGIN`. Match this to whatever URL users will type into their address bar.
PUBLIC_BASE_URL=http://localhost:8080

# Host ports Caddy binds.
HOST_HTTP_PORT=8080
HOST_HTTPS_PORT=8443


# ----- Postgres -----

POSTGRES_USER=dds
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=dds


# ----- Clustering server -----

# Where the clustering server connects to publish DDS records. Leave unset (or empty) to run
# the server in read-only mode (it will compute analyses but skip republication).
DDS_CS_SERVICE_HANDLE=
DDS_CS_SERVICE_APP_PASSWORD=

# Bluesky service URL (PDS).
DDS_CS_BSKY_SERVICE=https://bsky.social

# Jetstream endpoint to subscribe to.
DDS_CS_JETSTREAM_ENDPOINT=wss://jetstream1.us-east.bsky.network/subscribe

# Default rerun threshold for new analyses (overridable per-analysis via the API).
DDS_CS_DEFAULT_RERUN_THRESHOLD=10

DDS_CS_LOG_LEVEL=INFO
