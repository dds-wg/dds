{
  "name": "@dds/indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "DDS indexer: subscribes to jetstream, persists records, serves project-scoped queries.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@dds/client": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@skyware/jetstream": "^0.2.5",
    "better-sqlite3": "^12.11.0",
    "drizzle-orm": "^0.45.0",
    "fastify": "^5.8.0",
    "pg": "^8.22.0",
    "pino-pretty": "^13.1.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3"
  }
}
