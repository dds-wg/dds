{
  "lexicon": 1,
  "id": "org.dds-wg.v1.decision",
  "description": "A decision made by a user or algorithm, optionally pointing to the proposals that were accepted into it.",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["name", "summary", "creator", "createdAt"],
        "properties": {
          "schemaVersion": { "type": "string", "maxLength": 32 },
          "name": { "type": "string", "maxLength": 200 },
          "summary": { "type": "string", "maxLength": 10000 },
          "creator": {
            "type": "union",
            "refs": ["org.dds-wg.v1.defs#userAgent", "org.dds-wg.v1.defs#algorithmAgent"]
          },
          "acceptedProposals": {
            "type": "array",
            "items": { "type": "ref", "ref": "com.atproto.repo.strongRef" }
          },
          "step": { "type": "ref", "ref": "org.dds-wg.v1.defs#projectStepRef" },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
